# ─── GETH / BLOCKCHAIN ───────────────────────────────
IPC_SOCKET_PATH=/var/lib/geth/sepolia/geth.ipc
MFS_CONTRACT_ADDRESS=0x...
MFS_COMPANY_FEE_ADDRESS=0x...
MFS_MAIN_WALLET_ADDRESS=0x...
SEPOLIA_CHAIN_ID=11155111

# ─── DATABASE ────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/mfs_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mfs_db
DB_USER=user
DB_PASS=pass

# ─── REDIS ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-random-256-bit
JWT_REFRESH_SECRET=change-me-to-random-256-bit
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── SENDGRID (EMAIL OTP) ────────────────────────────
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@mfscrypto.com

# ─── TWILIO (SMS OTP) ────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── META WHATSAPP CLOUD API ─────────────────────────
META_WA_TOKEN=xxxx
META_WA_PHONE_NUMBER_ID=xxxx
META_WA_TEMPLATE_NAME=mfs_otp

# ─── FIREBASE (PUSH NOTIFICATIONS) ───────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-key.json

# ─── APP ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000
